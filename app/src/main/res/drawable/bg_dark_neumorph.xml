<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer slight shadow indication -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#212327" />
            <corners android:radius="24dp" />
            <stroke android:width="2dp" android:color="#36393F" />
        </shape>
    </item>
    <!-- Main base -->
    <item android:top="2dp" android:left="2dp" android:right="2dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#2A2D32" />
            <corners android:radius="22dp" />
        </shape>
    </item>
</layer-list>
