<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer Glow / Shadow -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="32dp" />
            <solid android:color="#0D000000" />
            <padding android:bottom="2dp" android:left="2dp" android:right="2dp" android:top="2dp" />
        </shape>
    </item>

    <!-- Main Glass Body -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="28dp" />
            <gradient
                android:startColor="#B3FFFFFF"
                android:centerColor="#80FFFFFF"
                android:endColor="#66FFFFFF"
                android:angle="135" />
            <stroke
                android:width="1.5dp"
                android:color="#4DFFFFFF" />
        </shape>
    </item>
    
    <!-- Subtle Inner Reflection (Top) -->
    <item android:bottom="40dp" android:left="1dp" android:right="1dp" android:top="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="26dp" />
            <gradient
                android:startColor="#33FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="270" />
        </shape>
    </item>
</layer-list>
