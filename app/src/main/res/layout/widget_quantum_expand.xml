<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_quantum_glass">

        <FrameLayout
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:padding="14dp">
            
            <View
                android:id="@+id/user_circle"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/hex_bloom_cyan" />

            <ImageView
                android:id="@+id/user_icon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:src="@drawable/ic_user_premium"
                android:scaleType="fitCenter" />
        </FrameLayout>

        <TextView
            android:id="@+id/active_count_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="1/5 SYNCED"
            android:textColor="#00E5FF"
            android:textSize="8sp"
            android:textStyle="bold"
            android:fontFamily="monospace" />

        <ImageView
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:src="@android:drawable/arrow_down_float"
            android:alpha="0.4"
            android:contentDescription="Expand" />

    </LinearLayout>

</FrameLayout>
