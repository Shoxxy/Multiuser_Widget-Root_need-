<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Deep Digital Base -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <solid android:color="#F2000A14" />
        </shape>
    </item>

    <!-- Cyan Rim Highlight -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <stroke
                android:width="1.5dp"
                android:color="#B300E5FF" />
            <gradient
                android:startColor="#1A00E5FF"
                android:endColor="#00000000"
                android:angle="135" />
        </shape>
    </item>

    <!-- Scanline Detail -->
    <item android:top="2dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="10dp" />
            <gradient
                android:startColor="#0DFFFFFF"
                android:centerColor="#00FFFFFF"
                android:endColor="#0DFFFFFF"
                android:angle="90" />
        </shape>
    </item>
</layer-list>
