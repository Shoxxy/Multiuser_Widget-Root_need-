<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer Shadow / Depth -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <solid android:color="#40000000" />
            <padding android:bottom="1dp" android:left="1dp" android:right="1dp" android:top="1dp" />
        </shape>
    </item>

    <!-- Main Obsidian Body -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="22dp" />
            <gradient
                android:startColor="#E60A0A0A"
                android:centerColor="#D9121212"
                android:endColor="#E6050505"
                android:angle="135" />
            <!-- Sharp Premium Rim -->
            <stroke
                android:width="1.2dp"
                android:color="#4DFFFFFF" />
        </shape>
    </item>
    
    <!-- Top-Left Gloss Reflection -->
    <item android:bottom="40dp" android:left="2dp" android:right="2dp" android:top="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <gradient
                android:startColor="#1AFFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="135" />
        </shape>
    </item>
</layer-list>
